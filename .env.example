# Public site URL (used by metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — transactional email (resend)
RESEND_API_KEY=

# Neon — serverless Postgres (@neondatabase/serverless)
DATABASE_URL=

# Upstash Redis (@upstash/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob storage (@vercel/blob) — admin blog image uploads
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────
# Blog + mini-CMS (file-based; publishes via GitHub)
# ─────────────────────────────────────────────

# Admin login at /blog/blog-admin
BLOG_ADMIN_PASSWORD=

# Draft preview: /blog/<slug>?preview=<token>
BLOG_PREVIEW_TOKEN=

# Production publishing — commits posts to the repo Vercel deploys from.
# Fine-grained PAT with Contents: Read/Write + Metadata: Read on this repo.
GITHUB_TOKEN=
GITHUB_REPO=J-as-minee/Learnbee_marketing
GITHUB_BRANCH=main

# Draft autosave uses Upstash above (UPSTASH_REDIS_REST_*). Vercel KV naming
# (KV_REST_API_URL / KV_REST_API_TOKEN) is also accepted if you prefer it.

# Leave empty on Learnbee — no external image fallback origin.
BLOG_IMAGE_FALLBACK_ORIGIN=

# Optional — newsletter + lead form emails (add when Resend is set up)
NEWSLETTER_NOTIFY_EMAIL=
LEADS_NOTIFY_EMAIL=
NEWSLETTER_EMAIL_FROM="Learnbee <onboarding@resend.dev>"
LEADS_EMAIL_FROM="Learnbee <onboarding@resend.dev>"
