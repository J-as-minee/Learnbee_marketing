# Blog system — add to Learnbee .env.local / Vercel

NEXT_PUBLIC_SITE_URL=https://learnbee.com

# Preview drafts: /blog/[slug]?preview=<token>
BLOG_PREVIEW_TOKEN=change_me_preview_token

# Admin login: /blog/blog-admin
BLOG_ADMIN_PASSWORD=change_me_admin_password

# Production writes from Vercel (read-only disk)
GITHUB_TOKEN=
GITHUB_REPO=owner/learnbee-website
GITHUB_BRANCH=main

# Admin image uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Draft autosave in admin (Vercel KV / Upstash)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Newsletter + lead forms (Resend)
RESEND_API_KEY=
NEWSLETTER_NOTIFY_EMAIL=
LEADS_NOTIFY_EMAIL=
NEWSLETTER_EMAIL_FROM="Learnbee <onboarding@resend.dev>"
LEADS_EMAIL_FROM="Learnbee <onboarding@resend.dev>"

# Disable Bsharp fallback — not used on Learnbee
BLOG_IMAGE_FALLBACK_ORIGIN=
